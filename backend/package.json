{
  "name": "iron-booking",
  "version": "1.0.0",
  "description": "Professional restaurant host and reservation system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
"render-build": "npx prisma generate && npx prisma migrate deploy && tsc -p tsconfig.json"    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.19.2",
    "luxon": "^3.4.4",
    "nanoid": "^3.3.7",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.5.0",
    "prisma": "^5.14.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": "20.x"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adelbiady-netizen/iron-booking.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/adelbiady-netizen/iron-booking/issues"
  },
  "homepage": "https://github.com/adelbiady-netizen/iron-booking#readme"
}