generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Restaurant Group ────────────────────────────────────────────────────────
// Lightweight group entity for future multi-branch / chain support.
// Restaurants that are standalone (the common case) leave groupId null.

model RestaurantGroup {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  settings  Json     @default("{}") // future: chain-level defaults, branding, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurants Restaurant[]
  users       User[] // HQ-level users who span multiple branches

  @@map("restaurant_groups")
}

// ─── Restaurant ─────────────────────────────────────────────────────────────

model Restaurant {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  timezone String  @default("America/New_York")
  phone    String?
  email    String?
  address  String?

  // Operational settings stored as structured JSON
  settings Json @default("{}")
  // {
  //   defaultTurnMinutes: number        (e.g. 90)
  //   slotIntervalMinutes: number       (e.g. 15)
  //   maxPartySize: number              (e.g. 20)
  //   depositRequired: boolean
  //   depositAmountCents: number
  //   autoConfirm: boolean
  //   bufferBetweenTurnsMinutes: number (e.g. 15 — cleaning/reset time)
  //   openingHour: string               "11:00"
  //   closingHour: string               "22:00"
  //   lastSeatingOffset: number         minutes before close (e.g. 60)
  //   minimumOperationalWindowMinutes: number (e.g. 15 — min time shown on seated table timer)
  //   serviceDayCutoffHour: number | null     (e.g. 4 — times 00:00–03:59 belong to the prior
  //                                            service day's anchor date; null = disabled)
  //
  //   ── SMS / Messaging (Phase 1 — Iron Messaging) ──────────────────────────
  //   smsEnabled: boolean               (default false — restaurant must opt in)
  //   smsSenderName: string             (e.g. "IronGrill" — appears as SMS sender ID)
  //   smsMonthlyQuota: number           (max outbound messages per month; 0 = unlimited)
  //   smsUsedThisMonth: number          (running count; reset on first send of new month)
  //   smsFallbackEnabled: boolean       (default false — future WhatsApp fallback if SMS fails)
  //   smsProvider: 'INFORU' | 'MOCK'   (default 'MOCK'; switch to 'INFORU' when credentials ready)
  //
  //   ── Reminders (Phase 5A — Iron Messaging) ───────────────────────────────
  //   reminderEnabled: boolean          (default true — set false to disable all reminder sends)
  //   reminderLeadMinutes: number       (minutes ahead to include in bulk reminder window; default 60)
  //
  //   ── IRON CLUB ────────────────────────────────────────────────────────────
  //   ironClubEnabled: boolean          (master switch — false disables ALL club sub-modules)
  //   ironClubTier: IronClubTier        ('NONE' | 'STARTER' | 'MEMBER' | 'INTELLIGENCE' | 'LUXURY')
  //   feedbackApprovalRequired: boolean (default true — feedback SMS requires MANAGER approval before send)
  // }

  // Link telephony DID — the number the system routes calls to for this restaurant.
  // Used to match incoming call webhooks to the correct restaurant.
  linkPhone String? @unique

  // Per-restaurant WhatsApp (UltraMsg) credentials — optional; if absent, no messages sent
  ultramsgInstanceId String?
  ultramsgToken      String?
  whatsappPhone      String?

  // Restaurant group — null for standalone restaurants (the current default)
  groupId String?
  group   RestaurantGroup? @relation(fields: [groupId], references: [id])

  // Set true for the internal _system restaurant that SUPER_ADMIN users belong to
  isSystem Boolean @default(false)

  // Public-facing profile (all nullable — shown on guest confirmation page)
  logoUrl             String?
  coverImageUrl       String?
  description         String?
  cuisine             String?
  websiteUrl          String?
  instagramUrl        String?
  googleMapsUrl       String?
  wazeUrl             String?
  parkingNotes        String?
  cancellationPolicy  String?
  specialInstructions String?

  // Public guest-page branding
  primaryColor          String? // hex, e.g. "#C9A84C"
  accentColor           String? // hex, secondary accent
  publicThemePreset     String? // "luxury" | "casual" | "family" | "nightlife" | "minimal" | "fineDining" | "mediterranean" | "italiano"
  heroVideoUrl          String? // muted autoplay background video for the public booking page
  buttonStyle           String? // "rounded" | "pill" | "sharp" | "luxury"
  cardStyle             String? // "glass" | "solid" | "luxury-dark" | "soft-light"
  backgroundMood        String? // "espresso" | "olive" | "cream" | "dark" | "warm"
  backgroundColorHex    String? // custom bg base color, e.g. "#1a0f05"; overrides mood preset
  backgroundGradientHex String? // optional gradient end color, e.g. "#0a0603"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                     User[]
  guests                    Guest[]
  callLogs                  CallLog[]
  tables                    Table[]
  tableCombinations         TableCombination[]
  sections                  Section[]
  reservations              Reservation[]
  waitlistEntries           WaitlistEntry[]
  blockedPeriods            BlockedPeriod[]
  operatingHours            OperatingHour[]
  floorObjects              FloorObject[]
  onlineBookingRestrictions OnlineBookingRestriction[]
  portalPermissions         RestaurantPortalPermissions?
  messageLogs               MessageLog[]
  guestMemories             GuestMemory[]
  guestAlerts               GuestAlert[]
  recoveryCases             RecoveryCase[]
  momentQueue               MomentQueue[]
  morningBriefs             MorningBrief[]
  guestFeedback             GuestFeedback[]
  clubMembers               ClubMember[]
  clubJoinInvites           ClubJoinInvite[]
  guestRewards              GuestReward[]
  consentAudits             ConsentAudit[]
  unsubscribeTokens         UnsubscribeToken[]
  opProfile                 RestaurantOpProfile?

  @@map("restaurants")
}

// ─── Restaurant Portal Permissions ───────────────────────────────────────────
// Per-restaurant feature gates for the RESTAURANT_ADMIN portal.
// Default false = deny-by-default; HQ explicitly grants each capability.

model RestaurantPortalPermissions {
  id                          String     @id @default(uuid())
  restaurant                  Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId                String     @unique
  canManageOperatingHours     Boolean    @default(false)
  canManageOnlineRestrictions Boolean    @default(false)
  updatedAt                   DateTime   @updatedAt

  @@map("restaurant_portal_permissions")
}

// ─── Users (Staff) ──────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  restaurantId String // always set — HQ users are tied to their primary branch or the system restaurant
  email        String? // null for PIN-only floor hosts
  passwordHash String? // null for PIN-only floor hosts
  pin          String? // bcrypt-hashed 4-digit PIN for floor login
  avatarUrl    String?
  firstName    String
  lastName     String
  role         UserRole  @default(HOST)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  // Group membership — set for HQ_ADMIN / GROUP_MANAGER users who span branches.
  // Null for all existing restaurant-scoped users (backward safe).
  groupId String?
  group   RestaurantGroup? @relation(fields: [groupId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant      Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  redeemedRewards GuestReward[]

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@index([groupId])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN // system-wide admin (all restaurants, cross-group)
  HQ_ADMIN // group-level admin (all branches within their group)
  GROUP_MANAGER // group-level manager (limited cross-branch access)
  RESTAURANT_ADMIN // single-restaurant admin (portal access scoped to own restaurant)
  OWNER // restaurant owner (restaurant-scoped, highest branch role)
  ADMIN // restaurant-level admin (kept for backward compatibility)
  MANAGER // restaurant manager
  HOST // floor host
  SERVER // server (read-mostly)
}

// ─── Operating Hours ─────────────────────────────────────────────────────────

model OperatingHour {
  id           String  @id @default(uuid())
  restaurantId String
  dayOfWeek    Int // 0=Sunday … 6=Saturday
  openTime     String // "HH:mm"
  closeTime    String // "HH:mm"
  lastSeating  String // "HH:mm" — last reservation slot
  isOpen       Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@map("operating_hours")
}

// ─── Sections ────────────────────────────────────────────────────────────────

model Section {
  id           String  @id @default(uuid())
  restaurantId String
  name         String // "Main Dining", "Bar", "Patio", "Private"
  sortOrder    Int     @default(0)
  color        String  @default("#6366f1") // UI color for section
  onlineAvailable Boolean @default(true) // false = section never shown in online booking

  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables       Table[]
  groupConfigs BookingGroupConfig[]

  @@unique([restaurantId, name])
  @@map("sections")
}

// ─── Tables ──────────────────────────────────────────────────────────────────

model Table {
  id           String     @id @default(uuid())
  restaurantId String
  sectionId    String?
  name         String // "T1", "Bar 3", "Patio 7"
  minCovers    Int
  maxCovers    Int
  shape        TableShape @default(RECTANGLE)
  isCombinable Boolean    @default(false)
  isActive     Boolean    @default(true)

  // Floor plan position (pixels, relative to section canvas)
  posX     Float @default(0)
  posY     Float @default(0)
  width    Float @default(80)
  height   Float @default(80)
  rotation Float @default(0)

  // Override turn time at table level (null = use restaurant default)
  turnTimeMinutes Int?

  notes String? // permanent notes ("wobbly leg", "near kitchen")

  // Operational lock — independent of timed BlockedPeriods
  locked      Boolean   @default(false)
  lockReason  String?
  lockedUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  section        Section?           @relation(fields: [sectionId], references: [id])
  reservations   Reservation[]
  blockedPeriods BlockedPeriod[]
  combinationsA  TableCombination[] @relation("CombinationTableA")
  combinationsB  TableCombination[] @relation("CombinationTableB")

  @@unique([restaurantId, name])
  @@index([restaurantId, sectionId])
  @@map("tables")
}

enum TableShape {
  ROUND
  SQUARE
  RECTANGLE
  OVAL
  BOOTH
}

// ─── Table Combinations ──────────────────────────────────────────────────────
// Pre-defined joinable table configs. A combination is two adjacent tables
// that can be pushed together. For 3+ tables, model as chained pairs.

model TableCombination {
  id           String  @id @default(uuid())
  restaurantId String
  name         String // "T1+T2", "Boardroom"
  tableAId     String
  tableBId     String
  minCovers    Int
  maxCovers    Int
  isActive     Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableA     Table      @relation("CombinationTableA", fields: [tableAId], references: [id])
  tableB     Table      @relation("CombinationTableB", fields: [tableBId], references: [id])

  @@unique([restaurantId, tableAId, tableBId])
  @@map("table_combinations")
}

// ─── Guests (CRM) ────────────────────────────────────────────────────────────

model Guest {
  id           String  @id @default(uuid())
  restaurantId String
  firstName    String
  lastName     String
  email        String?
  phone        String?

  isVip         Boolean @default(false)
  isBlacklisted Boolean @default(false)

  // Stored as arrays of strings for flexibility
  allergies   String[] @default([])
  tags        String[] @default([]) // "birthday regular", "wine lover"
  preferences Json     @default("{}") // { seatingPref: "window", dietaryNotes: "" }

  internalNotes String? // host-only notes, not shown to guest

  // Aggregated stats (updated via triggers or scheduled job)
  visitCount  Int       @default(0)
  noShowCount Int       @default(0)
  cancelCount Int       @default(0)
  lastVisitAt DateTime?

  // Guest Intelligence Center — computed nightly
  firstVisitAt          DateTime?
  avgVisitIntervalDays  Float?     // personal visit rhythm
  nextExpectedVisitDate DateTime?  // lastVisitAt + avgVisitIntervalDays
  silentScore           Int?       // 0–100, higher = more at risk (V1 — preserved)
  vipScore              Int?       // 0–100 (V1 — preserved for backward compat)
  gicComputedAt         DateTime?  // when scores were last refreshed

  // V2 multi-factor scoring
  loyaltyScore    Int?    // 0–100: multi-signal loyalty score (replaces vipScore long-term)
  engagementScore Int?    // 0–100: breadth of engagement signals fired
  gicLabel        String? // classification: VIP | LOYAL | VIP_CANDIDATE | HIGH_ENGAGEMENT | RECOVERED | AT_RISK | SILENT | NEEDS_ATTENTION | CRM_MEMBER | NEW

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations    Reservation[]
  waitlistEntries WaitlistEntry[]
  messageLogs     MessageLog[]
  memories        GuestMemory[]
  alerts          GuestAlert[]
  recoveryCases   RecoveryCase[]
  momentQueue     MomentQueue[]
  feedback        GuestFeedback[]
  clubMemberships    ClubMember[]
  rewards            GuestReward[]
  consentAudits      ConsentAudit[]
  unsubscribeTokens  UnsubscribeToken[]

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@index([restaurantId, phone])
  @@index([restaurantId, lastName])
  @@map("guests")
}

// ─── Reservations ────────────────────────────────────────────────────────────

model Reservation {
  id               String   @id @default(uuid())
  restaurantId     String
  guestId          String?
  tableId          String? // null until assigned (primary table)
  combinedTableIds String[] @default([]) // secondary tables for combined seatings

  // Booking details
  partySize Int
  date      DateTime @db.Date // date only
  time      String // "HH:mm" — stored separately for slot logic
  duration  Int // minutes (computed from restaurant default + overrides)

  status ReservationStatus @default(PENDING)
  source ReservationSource @default(PHONE)

  // Guest info (denormalized for speed — allows reservations without Guest record)
  guestName  String
  guestPhone String?
  guestEmail String?

  // Occasion & special requests
  occasion   String? // "birthday", "anniversary", "business"
  guestNotes String? // what the guest told us
  hostNotes  String? // internal host notes
  guestLang  String? // "en" | "he" — captured at booking; used for WhatsApp

  // Guest club / marketing consent (explicit opt-in from public booking form)
  marketingOptIn         Boolean   @default(false)
  birthday               String? // "MM-DD" — annual; year not stored
  anniversary            String? // "MM-DD" — annual; year not stored
  marketingConsentAt     DateTime?
  marketingConsentSource String? // "PUBLIC_BOOKING"

  // Tags for filtering/reporting
  tags String[] @default([])

  // Deposit tracking
  depositRequired    Boolean   @default(false)
  depositAmountCents Int?
  depositPaidAt      DateTime?
  depositRefundedAt  DateTime?

  // Guest confirmation (SMS/link flow)
  isConfirmedByGuest Boolean   @default(false)
  confirmationToken  String?   @unique
  confirmationSentAt DateTime?

  // Guest self-reported running late (set via confirmation link)
  isRunningLate  Boolean   @default(false)
  lateNotifiedAt DateTime?

  // Host-marked physical arrival — guest is present but not yet seated
  isArrived Boolean   @default(false)
  arrivedAt DateTime?

  // Lifecycle timestamps
  confirmedAt      DateTime?
  remindedAt       DateTime?
  reminderCount    Int       @default(0)
  seatedAt         DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  noShowAt         DateTime?
  returnedToListAt DateTime? // set on unseat; cleared when host acts again

  // Reorganize — set when a future reservation is displaced from its table during seating
  reorganizeAt          DateTime? // set when displaced; cleared on resolution
  reorganizeFromTableId String? // audit: which table was cleared
  reorganizeBySeatingId String? // audit: which reservation triggered displacement

  // For move history — which table was previously assigned
  previousTableId String?

  // Host attribution — who performed key operational actions
  createdByName     String?
  updatedByName     String?
  seatedByName      String?
  cancelledByName   String?
  movedByName       String?
  reorganizedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant  Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest       Guest?                @relation(fields: [guestId], references: [id])
  table       Table?                @relation(fields: [tableId], references: [id])
  activityLog    ReservationActivity[]
  messageLogs    MessageLog[]
  guestMemories  GuestMemory[]
  recoveryCases  RecoveryCase[]
  feedback       GuestFeedback?

  @@index([restaurantId, date])
  @@index([restaurantId, status])
  @@index([restaurantId, tableId, date])
  @@index([guestId])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING // created, not yet confirmed
  CONFIRMED // confirmed (deposit paid or auto-confirmed)
  SEATED // guest is at the table
  COMPLETED // table cleared, turn complete
  CANCELLED // cancelled by guest or host
  NO_SHOW // guest never arrived
}

enum ReservationSource {
  ONLINE // direct online booking
  PHONE // phone call
  WALK_IN // converted from walk-in/waitlist
  OPENTABLE // OT integration
  RESY // Resy integration
  INTERNAL // created by host in the system
}

// ─── Reservation Activity Log ────────────────────────────────────────────────

model ReservationActivity {
  id            String   @id @default(uuid())
  reservationId String
  action        String // "CONFIRMED", "TABLE_ASSIGNED", "MOVED", "NOTE_ADDED", etc.
  actor         String // user name or "system"
  details       Json? // { from: X, to: Y } etc.
  timestamp     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@map("reservation_activity")
}

// ─── Waitlist ─────────────────────────────────────────────────────────────────

model WaitlistEntry {
  id           String         @id @default(uuid())
  restaurantId String
  guestId      String? // nullable FK — auto-linked on add/seat
  date         DateTime       @db.Date
  guestName    String
  guestPhone   String?
  partySize    Int
  status       WaitlistStatus @default(WAITING)
  source       WaitlistSource @default(WALK_IN)

  // Quote given when added
  quotedWaitMinutes Int?

  // Timestamps
  addedAt    DateTime  @default(now())
  notifiedAt DateTime? // when we sent "table ready" notification
  seatedAt   DateTime?
  leftAt     DateTime? // guest decided to leave

  notes String?

  // Public self-service waitlist fields
  publicToken   String? @unique // opaque guest tracking token
  preferredTime String? // "HH:MM" requested time
  flexibleTime  Boolean @default(false) // guest accepts ±1 hour

  // If converted to reservation
  reservationId String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest      Guest?     @relation(fields: [guestId], references: [id])

  @@index([restaurantId, date, status])
  @@index([restaurantId, guestId])
  @@map("waitlist_entries")
}

enum WaitlistStatus {
  WAITING
  NOTIFIED // told table is ready, waiting confirmation
  SEATED
  LEFT // chose to leave
  REMOVED // host removed
  ARCHIVED // auto-closed at end of operational day
}

enum WaitlistSource {
  WALK_IN
  PHONE
  ONLINE
  PUBLIC_ONLINE
}

// ─── Blocked Periods ─────────────────────────────────────────────────────────
// Block a table or the entire restaurant for events, maintenance, VIP holds.

model BlockedPeriod {
  id           String    @id @default(uuid())
  restaurantId String
  tableId      String? // null = all tables (restaurant-level block)
  reason       String
  type         BlockType @default(EVENT)
  startTime    DateTime
  endTime      DateTime
  createdBy    String // user name

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table?     @relation(fields: [tableId], references: [id])

  @@index([restaurantId, tableId, startTime, endTime])
  @@map("blocked_periods")
}

enum BlockType {
  EVENT // private event
  MAINTENANCE // table out of service
  VIP_HOLD // holding for a specific guest
  STAFF_MEAL
}

// ─── Floor Plan Objects ───────────────────────────────────────────────────────
// Non-table decorative/structural elements: walls, zones, bars, etc.
// Scoped to a restaurant; fully independent of reservations and table lifecycle.

model FloorObject {
  id           String       @id @default(uuid())
  restaurantId String
  kind         FloorObjKind
  label        String
  posX         Float        @default(0)
  posY         Float        @default(0)
  width        Float        @default(100)
  height       Float        @default(20)
  rotation     Float        @default(0)
  color        String?
  variant      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("floor_objects")
}

enum FloorObjKind {
  WALL
  DIVIDER
  BAR
  ENTRANCE
  ZONE
  PLANTER
  HOST_STAND
  SERVICE_LANE
  LOUNGE_BOUNDARY
  VIP_ENCLOSURE
  CURVED_LOUNGE_BOUNDARY
  CURVED_BOOTH_SEGMENT
}

// ─── Call Logs (Link telephony webhook) ──────────────────────────────────────

model CallLog {
  id           String   @id @default(uuid())
  restaurantId String? // null when called number doesn't match any restaurant
  phone        String // caller (ANI)
  called       String? // dialed number (DNIS) — used for restaurant routing
  group        String? // Link call group / ring group
  extension    String? // Link extension reached
  callid       String? // provider-issued call identifier; shared across ring/answered events
  status       String
  duration     Int? // seconds; null when not provided
  recordUrl    String?
  createdAt    DateTime @default(now())

  // ── Phase-128 routing metadata ────────────────────────────────────────────
  // Null on records created before Phase 128.
  routingStatus  String? // "resolved" | "unresolved"
  category       String? // "reservation" | future categories
  channel        String? // "phone" | "sms" | future channels
  restaurantName String? // denormalised; set when group routing resolves to a known target
  guestName      String? // denormalised snapshot — first+last at call time; null if no match

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])

  @@index([phone])
  @@index([restaurantId])
  @@index([callid])
  @@map("call_logs")
}

// ─── Guest Hub ────────────────────────────────────────────────────────────────
// Isolated public digital experience — QR menus, promos, venue info.
// Served at /api/public/hub/:slug (unauthenticated, read-only).
//
// ISOLATION: Never join to Reservation, WaitlistEntry, Table, Section, or
// any SSE/floor model. All hub data lives in its own namespace and can be
// extracted to a separate service without touching operational logic.

model GuestHub {
  id              String               @id @default(uuid())
  slug            String               @unique // canonical URL slug — /r/ember-stone
  restaurantId    String? // soft link; hub may outlive a restaurant record
  isActive        Boolean              @default(true)
  publicStatus    GuestHubPublicStatus @default(PUBLISHED) // see enum — DRAFT for new provisions
  lastPublishedAt DateTime? // null = never published
  // i18n: locale of default content. Future: per-entity translation table
  // keyed on (entityType, entityId, locale, field).
  defaultLocale   String?              @default("en")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  branding             GuestHubBranding?
  menus                GuestHubMenu[]
  promotions           GuestHubPromotion[]
  events               GuestHubEvent[]
  socialLinks          GuestHubSocialLink[]
  qrTokens             GuestHubQrToken[]
  publishedBranding    GuestHubPublishedBranding?
  publishedSocialLinks GuestHubPublishedSocialLink[]

  @@map("guest_hub")
}

model GuestHubBranding {
  id             String   @id @default(uuid())
  hubId          String   @unique
  name           String
  tagline        String?
  about          String? // short identity paragraph shown on Guest Hub (max 250 chars)
  estYear        Int? // establishment year, e.g. 2018 — displayed as "Est. 2018" in hero
  features       String[] @default([]) // fixed vocab: OUTDOOR_SEATING | PRIVATE_DINING | LIVE_MUSIC | VEGAN_OPTIONS | ROOFTOP | CHEFS_CHOICE
  galleryImages  String[] @default([]) // ordered Cloudinary URLs, max 10
  galleryEnabled Boolean  @default(false) // explicit opt-in; false = section never renders even if images exist
  phone          String?
  address        String?
  directionsUrl  String?
  logoUrl        String?
  coverImageUrl  String?
  primaryColor   String? // hex — overrides themePreset
  accentColor    String?
  themePreset    String? // preset key: "luxury" | "fineDining" | "casual" etc.
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hub GuestHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@map("guest_hub_branding")
}

model GuestHubMenu {
  id        String   @id @default(uuid())
  hubId     String
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hub        GuestHub               @relation(fields: [hubId], references: [id], onDelete: Cascade)
  categories GuestHubMenuCategory[]

  @@unique([hubId, name])
  @@map("guest_hub_menu")
}

model GuestHubMenuCategory {
  id          String   @id @default(uuid())
  menuId      String
  name        String
  description String? // optional sub-heading shown under category name
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isHidden    Boolean  @default(false) // soft-hide: excluded from public, visible in CMS
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menu   GuestHubMenu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dishes GuestHubDish[]

  @@unique([menuId, name])
  @@map("guest_hub_menu_category")
}

model GuestHubDish {
  id           String           @id @default(uuid())
  categoryId   String
  name         String
  subtitle     String? // secondary line: "Pan-seared, with seasonal greens"
  description  String?
  price        String? // display string: "$38", "Market price", "48 ₪"
  tag          String? // "Chef's pick", "Seasonal", "New"
  dietaryTags  String[]         @default([]) // ["vegan","gluten-free","halal","kosher"]
  availability DishAvailability @default(AVAILABLE)
  isFeatured   Boolean          @default(false)
  featuredRank Int? // ordering within featured carousel; null = unranked
  sortOrder    Int              @default(0)
  imageUrl     String?
  gradient     String? // CSS gradient fallback when imageUrl is absent
  isActive     Boolean          @default(true)
  isHidden     Boolean          @default(false) // soft-hide: excluded from public, visible in CMS
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Future: GuestHubDishTranslation(dishId, locale, name, subtitle, description)

  category GuestHubMenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@map("guest_hub_dish")
}

enum DishAvailability {
  AVAILABLE
  SOLD_OUT // 86'd today; shown dimmed in menu
  SEASONAL // available only in season; shown with badge
  BREAKFAST_ONLY
  DINNER_ONLY
}

// Controls public visibility of a Guest Hub page.
// DRAFT    = provisioned but not yet activated; /r/:slug returns 404.
// PUBLISHED = live and publicly visible; QR scans resolve normally.
// INACTIVE  = manually deactivated; /r/:slug returns 404; re-activatable.
// Default PUBLISHED so existing hubs remain live after schema migration.
enum GuestHubPublicStatus {
  DRAFT
  PUBLISHED
  INACTIVE
}

model GuestHubPromotion {
  id          String   @id @default(uuid())
  hubId       String
  title       String
  description String?
  schedule    String? // "Every Friday from 7:00 pm"
  tag         String?
  tagColor    String? // "gold" | "stone"
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hub GuestHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([hubId, title])
  @@map("guest_hub_promotion")
}

model GuestHubEvent {
  id          String    @id @default(uuid())
  hubId       String
  title       String
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  tag         String?
  tagColor    String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hub GuestHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([hubId, title])
  @@map("guest_hub_event")
}

model GuestHubSocialLink {
  id        String   @id @default(uuid())
  hubId     String
  platform  String // "instagram" | "tiktok" | "website" | "facebook"
  handle    String // username or full URL
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  hub GuestHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([hubId, platform])
  @@map("guest_hub_social_link")
}

// Published snapshots — atomically copied from draft on every Publish action.
// Public route reads these with draft fallback for backward compatibility.

model GuestHubPublishedBranding {
  id            String   @id @default(uuid())
  hubId         String   @unique
  name          String
  tagline       String?
  about         String?
  estYear       Int?
  features      String[] @default([])
  phone         String?
  address       String?
  logoUrl       String?
  coverImageUrl String?
  themePreset   String?
  publishedAt   DateTime

  hub GuestHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@map("guest_hub_published_branding")
}

model GuestHubPublishedSocialLink {
  id        String @id @default(uuid())
  hubId     String
  platform  String
  handle    String
  sortOrder Int    @default(0)

  hub GuestHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([hubId, platform])
  @@map("guest_hub_published_social_link")
}

// Stable opaque token mapped to a hub slug — slug can change, token never does.
// metadata is reserved for future table-aware context (Phase 103+).
// Structured as { tableName?, zone?, campaign?, source? } — stored as JSON so
// new attributes don't require schema migrations.
model GuestHubQrToken {
  id        String   @id @default(uuid())
  hubId     String
  token     String   @unique // URL-safe, stable identifier
  label     String? // "Table 5 QR", "Entrance QR"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // FUTURE: table-aware metadata (Phase 103+)
  // When table-mode ordering lands, populate: { tableName, zone, campaign, source }
  // TODO: revoke — set isActive=false, create new token, re-print affected cards
  // TODO: rotate — atomic revoke + create, preserve label, audit old token
  // TODO: archive — soft-delete with retainedUntil for attribution reporting
  metadata Json?

  hub GuestHub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([hubId, label])
  @@map("guest_hub_qr_token")
}

// ─── Online Booking Restrictions ─────────────────────────────────────────────
// Per-date/time-range rules that block public online booking for specific slots.
// Never affects host/admin manual reservation creation — public slot engine only.

model OnlineBookingRestriction {
  id              String   @id @default(uuid())
  restaurantId    String
  date            String // "YYYY-MM-DD"
  startTime       String? // "HH:mm" — null = full-day restriction
  endTime         String? // "HH:mm" — null = full-day restriction
  restrictionType String   @default("BLOCK") // BLOCK | PHONE_ONLY | VIP_ONLY | DEPOSIT_REQUIRED | WAITLIST_ONLY | MEMBERS_EVENT
  reason          String? // internal note, shown only to host
  guestMessage    String? // message shown in public booking widget
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  createdBy       String // staff user id

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, date])
  @@map("online_booking_restrictions")
}

// ─── Iron Messaging — SMS / Message Logs ─────────────────────────────────────
// Provider-agnostic outbound message log. Every SMS attempt is recorded here
// regardless of provider or outcome. MOCK provider used until InforU credentials
// are available (Phase 2).

model MessageLog {
  id                String               @id @default(uuid())
  restaurantId      String
  reservationId     String?
  guestId           String?
  clubMemberId      String?              // set when message is club-context (birthday, anniversary, etc.)
  phone             String
  messageType       MessageType
  channel           MessageChannel       @default(SMS)
  provider          MessageProvider
  senderName        String?              // alphanumeric sender shown to the guest; null for MOCK
  status            MessageStatus        @default(PENDING)
  providerMessageId String?
  errorMessage      String?
  costAgorot        Int?                 // provider-reported cost in agorot (1/100 ILS)
  segmentCount      Int?                 // SMS segment count (for billing; 1 segment ≈ 160 chars)
  body              String
  // Approval queue — set when feedbackApprovalRequired or future club message rules require it
  approvalRequired  Boolean              @default(false)
  approvalStatus    MessageApprovalStatus @default(AUTO_SENT)
  approvedBy        String?              // userId of approver
  approvedAt        DateTime?
  scheduledFor      DateTime?            // when to actually dispatch (null = immediate)
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservation  Reservation? @relation(fields: [reservationId], references: [id])
  guest        Guest?       @relation(fields: [guestId], references: [id])
  clubMember   ClubMember?  @relation(fields: [clubMemberId], references: [id])

  @@index([restaurantId])
  @@index([restaurantId, messageType])
  @@index([restaurantId, approvalStatus])
  @@index([reservationId])
  @@map("message_logs")
}

enum MessageType {
  // Reservation lifecycle
  CONFIRMATION
  CONFIRMATION_REQUEST
  REMINDER
  TABLE_READY
  WAITLIST
  RESERVATION_RECEIVED
  // Club / IRON CLUB
  FEEDBACK_REQUEST
  BIRTHDAY
  ANNIVERSARY
  WIN_BACK
  RECOVERY_OUTREACH
  VIP_OUTREACH
  BROADCAST
  // System
  MANUAL
  SYSTEM
}

enum MessageChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum MessageProvider {
  INFORU
  MOCK
}

enum MessageStatus {
  PENDING
  QUEUED_FOR_APPROVAL
  SENT
  DELIVERED
  FAILED
  REJECTED
}

enum MessageApprovalStatus {
  AUTO_SENT         // no approval required — sent immediately
  PENDING_APPROVAL  // waiting for a manager to approve
  APPROVED          // approved, will be sent at scheduledFor or immediately
  REJECTED          // manager rejected, will not be sent
}

// ─── Guest Intelligence Center ────────────────────────────────────────────────

enum MemoryCategory {
  CELEBRATION      // birthday, anniversary, engagement
  RECOVERY         // bad experience that was resolved
  EMOTIONAL_MOMENT // guest shared something personal
  MILESTONE        // 10th visit, 1 year guest, etc.
  PREFERENCE       // always orders X, prefers quiet corner
  GROUP_EVENT      // came with large party, corporate dinner
}

enum MemorySource {
  AUTO_DETECTED  // computed from reservation data
  HOST_ADDED     // manually typed by staff
}

enum AlertType {
  SILENT_GUEST      // hasn't returned in 2× their normal interval
  BIRTHDAY_SOON     // birthday within 7 days
  ANNIVERSARY_SOON  // anniversary within 7 days
  HIGH_NOSHOW       // 3+ no-shows
  RECOVERY_OPEN     // has an unresolved recovery case
  FEEDBACK_NEGATIVE // post-visit negative feedback received
  VIP_AT_RISK       // VIP guest showing silent/churn signals
}

enum RecoveryStatus {
  OPEN       // incident identified, no action yet
  CONTACTED  // staff reached out
  RESOLVED   // guest returned / confirmed recovered
}

enum RecoveryPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL   // VIP or loyal guest — escalated automatically
}

enum MomentType {
  LONG_RETURN          // guest returns after long absence
  BIRTHDAY_ECHO        // first visit near birthday
  ANNIVERSARY_ECHO     // first visit near anniversary
  RECOVERY_SEALED      // guest returned after bad experience
  FEEDBACK_REQUEST     // post-visit feedback invitation (requires approval if feedbackApprovalRequired)
}

enum IronClubTier {
  NONE           // club not active for this restaurant
  STARTER        // feedback collection + basic alerts
  MEMBER         // + ClubMember enrollment + recovery workflow
  INTELLIGENCE   // + VIP scoring + MomentQueue outbound
  LUXURY         // + gifts + birthday/anniversary automation + full campaign suite
}

enum ClubJoinSource {
  HOST_STAFF
  RESERVATION_LINK
  FEEDBACK_FLOW
  QR_CODE
  WEBSITE
  IMPORT
  MANUAL
}

enum ClubMemberStatus {
  ACTIVE
  PAUSED
  OPTED_OUT
}

enum MomentStatus {
  PENDING   // waiting for owner review
  APPROVED  // message will be sent
  REJECTED  // owner skipped
  SENT      // message dispatched
}

model GuestMemory {
  id             String         @id @default(uuid())
  restaurantId   String
  guestId        String
  reservationId  String?
  category       MemoryCategory
  source         MemorySource   @default(AUTO_DETECTED)
  headline       String         // "10th visit — always celebrates here"
  context        String?        // longer note
  emotionalWeight Int           @default(5) // 1–10
  occurredAt     DateTime
  isRecurring    Boolean        @default(false)
  recurMonth     Int?           // 1–12 for annual recurrences
  recurDay       Int?           // 1–31
  surfacedCount  Int            @default(0)
  lastSurfacedAt DateTime?
  isSuppressed   Boolean        @default(false)
  addedBy        String?        // userId if manually added
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest        Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  reservation  Reservation?  @relation(fields: [reservationId], references: [id])
  momentQueue  MomentQueue[]
}

model GuestAlert {
  id           String    @id @default(uuid())
  restaurantId String
  guestId      String
  type         AlertType
  headline     String
  context      String?
  isRead       Boolean   @default(false)
  isDismissed  Boolean   @default(false)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest      Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model RecoveryCase {
  id            String           @id @default(uuid())
  restaurantId  String
  guestId       String
  reservationId String?
  description   String           // what went wrong
  status        RecoveryStatus   @default(OPEN)
  priority      RecoveryPriority @default(NORMAL)
  assignedTo    String?          // staff name responsible for follow-up
  dueDate       DateTime?        // expected resolution date
  resolvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  restaurant  Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest       Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  reservation Reservation?     @relation(fields: [reservationId], references: [id])
  actions     RecoveryAction[]

  @@index([restaurantId, status])
  @@index([restaurantId, assignedTo])
  @@map("recovery_cases")
}

model RecoveryAction {
  id             String   @id @default(uuid())
  recoveryCaseId String
  actorName      String   // who took the action
  note           String
  createdAt      DateTime @default(now())

  case RecoveryCase @relation(fields: [recoveryCaseId], references: [id], onDelete: Cascade)

  @@map("recovery_actions")
}

model MomentQueue {
  id           String       @id @default(uuid())
  restaurantId String
  guestId      String
  memoryId     String?
  type         MomentType
  status       MomentStatus @default(PENDING)
  draftMessage String       // auto-generated draft for owner to edit
  finalMessage String?      // owner-edited version
  scheduledFor DateTime?    // when to send (if approved)
  sentAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest      Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  memory     GuestMemory? @relation(fields: [memoryId], references: [id])
}

model MorningBrief {
  id           String   @id @default(uuid())
  restaurantId String
  briefDate    DateTime // the date this brief covers (date-only)
  content      Json     // structured: { vipArrivals, birthdays, silentReturns, recoveryCases, totalCovers }
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, briefDate])
}

// ─── Guest Feedback ───────────────────────────────────────────────────────────

model GuestFeedback {
  id            String            @id @default(uuid())
  restaurantId  String
  guestId       String?
  reservationId String?           @unique
  token         String             @unique
  sentiment     FeedbackSentiment?
  freeText      String?
  tags          String[]          @default([])
  openedAt      DateTime?
  submittedAt   DateTime?
  createdAt     DateTime          @default(now())

  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest       Guest?       @relation(fields: [guestId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@index([restaurantId])
  @@index([guestId])
  @@map("guest_feedback")
}

enum FeedbackSentiment {
  EXCELLENT
  GOOD
  BAD
}

// ─── IRON CLUB ────────────────────────────────────────────────────────────────
// Per-restaurant club membership. A guest may hold memberships at multiple
// restaurants; uniqueness is scoped to (restaurantId, guestId).

model ClubMember {
  id                String           @id @default(uuid())
  restaurantId      String
  guestId           String
  joinDate          DateTime         @default(now())
  source            ClubJoinSource
  // Personal dates (MM-DD format — year intentionally omitted for privacy)
  birthday          String?          // "MM-DD"
  anniversary       String?          // "MM-DD"
  // Consent flags — explicit opt-in required before any club messaging
  marketingConsent  Boolean          @default(false)
  smsConsent        Boolean          @default(false)
  emailConsent      Boolean          @default(false)
  status            ClubMemberStatus @default(ACTIVE)
  notes             String?          // internal staff notes
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  restaurant         Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest              Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  messageLogs        MessageLog[]
  rewards            GuestReward[]
  consentAudits      ConsentAudit[]
  unsubscribeTokens  UnsubscribeToken[]

  @@unique([restaurantId, guestId])
  @@index([restaurantId])
  @@index([restaurantId, status])
  @@map("club_members")
}

// ─── Club Join Invite ─────────────────────────────────────────────────────────
// Token sent to a guest (via SMS, QR, or link) to invite them to join the club.
// One token per invite; a guest can have multiple invites over time.

model ClubJoinInvite {
  id           String    @id @default(uuid())
  restaurantId String
  token        String    @unique
  // Pre-fill hints (from reservation data — not personally stored until guest submits)
  guestName    String?
  guestPhone   String?
  guestId      String?   // set if we already have a Guest record
  reservationId String?
  // Lifecycle
  expiresAt    DateTime
  usedAt       DateTime? // null = not yet joined
  createdAt    DateTime  @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("club_join_invites")
}

// ─── HOSTESS TELEMETRY ────────────────────────────────────────────────────────
// Lightweight operational event log. Fire-and-forget from frontend.
// No dashboard yet — collecting data to understand real usage patterns.

model HostEvent {
  id           String   @id @default(uuid())
  restaurantId String
  hostName     String?
  event        String
  properties   Json?
  sessionId    String?
  createdAt    DateTime @default(now())

  @@index([restaurantId, event])
  @@index([restaurantId, createdAt])
  @@map("host_events")
}

// ─── IRON CLUB REWARDS ────────────────────────────────────────────────────────

enum RewardType {
  BIRTHDAY
  ANNIVERSARY
  RECOVERY
  MANUAL
}

enum RewardStatus {
  ISSUED
  REDEEMED
  EXPIRED
  CANCELLED
}

model GuestReward {
  id               String       @id @default(uuid())
  restaurantId     String
  guestId          String
  clubMemberId     String?
  type             RewardType
  title            String
  description      String?
  issuedAt         DateTime     @default(now())
  expiresAt        DateTime?
  status           RewardStatus @default(ISSUED)
  redeemedAt       DateTime?
  redeemedByUserId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest          Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  clubMember     ClubMember? @relation(fields: [clubMemberId], references: [id])
  redeemedByUser User?       @relation(fields: [redeemedByUserId], references: [id])

  @@index([restaurantId])
  @@index([restaurantId, status])
  @@index([guestId])
  @@index([expiresAt])
  @@map("guest_rewards")
}

// ─── Restaurant Operating Profile ────────────────────────────────────────────
// Single source of truth for restaurant operational behavior.
// One profile per restaurant (1:1). All rule sub-tables cascade from here.
// Absence of a profile = system defaults apply everywhere.

model RestaurantOpProfile {
  id           String @id @default(uuid())
  restaurantId String @unique

  // Seating philosophy — how the engine distributes incoming guests across tables.
  seatingPhilosophy SeatingPhilosophy @default(FILL_THEN_NEXT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  turnTimeRules TurnTimeRule[]
  timeWindows   BookingTimeWindow[]
  groupConfigs  BookingGroupConfig[]

  @@map("restaurant_op_profiles")
}

enum SeatingPhilosophy {
  FILL_THEN_NEXT // pack tables to capacity before moving to next section
  BALANCE        // spread covers evenly across sections
  KEEP_FLEXIBLE  // prefer smaller tables; hold combinations for large parties
}

// ─── Turn Time Rules ──────────────────────────────────────────────────────────
// Per party-size range turn time overrides.
// Engine evaluates rules in sortOrder; first match wins.
// If no rule matches, falls back to restaurant.settings.defaultTurnMinutes.

model TurnTimeRule {
  id          String  @id @default(uuid())
  profileId   String
  name        String  // "Large Groups", "Solo Diners"
  description String? // operator note

  // Party size range (inclusive both ends)
  partySizeMin Int
  partySizeMax Int

  durationMinutes Int
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile RestaurantOpProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("turn_time_rules")
}

// ─── Booking Time Windows ─────────────────────────────────────────────────────
// Override available time slots for online booking on specific days or dates.
// Example: Saturday → only 19:00–22:00 visible online.
// If no window applies for a given day the full operating hours are used.

model BookingTimeWindow {
  id          String  @id @default(uuid())
  profileId   String
  name        String  // "Saturday Evening Only", "Lunch Only"
  description String? // operator note

  // Scope: specificDate takes precedence over dayOfWeek when both are set.
  specificDate String? // "YYYY-MM-DD" — one-off override
  dayOfWeek   Int?    // 0=Sun … 6=Sat — recurring weekly rule

  startTime String // "HH:mm" — earliest slot visible online
  endTime   String // "HH:mm" — latest slot visible online

  sourceScope BookingSourceScope @default(ONLINE)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile RestaurantOpProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("booking_time_windows")
}

// v1 scope: ONLINE (guest-facing portal) and ALL.
// HOST scope reserved for v2 (host overrides without touching guest rules).
enum BookingSourceScope {
  ONLINE // online / guest-facing portal only
  HOST   // host-created reservations only (v2)
  ALL    // applies to every booking source
}

// ─── Booking Group Configs ────────────────────────────────────────────────────
// Routing rules for large-party online bookings.
// Example: 7–8 guests → ספות section, 2 tables, COMBINATION mode.

model BookingGroupConfig {
  id          String  @id @default(uuid())
  profileId   String
  name        String  // "Large Groups — Sofas"
  description String? // operator note

  // Party size range this rule applies to (inclusive)
  partySizeMin Int
  partySizeMax Int

  // Target section — null means any section is eligible
  targetSectionId String?

  // v1 supported: SINGLE (one table big enough) or COMBINATION (push tables together)
  allocationMode AllocationMode @default(SINGLE)

  // For COMBINATION: how many tables to join (v1 max = 2, matches TableCombination model)
  tableCount Int @default(1)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       RestaurantOpProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  targetSection Section?            @relation(fields: [targetSectionId], references: [id])

  @@index([profileId])
  @@map("booking_group_configs")
}

// v1 runtime: SINGLE + COMBINATION only.
// MULTI_TABLE (3+ arbitrary tables) reserved for v2 when TableCombination supports it.
enum AllocationMode {
  SINGLE      // assign one table that fits the entire party
  COMBINATION // combine tableCount pre-defined adjacent tables
  MULTI_TABLE // v2: arbitrary N-table join (not yet enforced by engine)
}

// ─── Consent Audit ────────────────────────────────────────────────────────────
// Immutable, append-only ledger of every consent change.
// Rows are NEVER updated or deleted — only INSERT is allowed.
// Answers: "How did this customer agree to receive messages?" with full evidence.

model ConsentAudit {
  id              String        @id @default(uuid())
  restaurantId    String
  guestId         String
  clubMemberId    String?       // null for reservation-level consent (pre-club)

  consentType     ConsentType
  action          ConsentAction
  source          ConsentSource

  // Snapshot of consent values at the moment of the event
  smsConsent      Boolean?
  marketingConsent Boolean?
  emailConsent    Boolean?

  // Legal evidence
  consentTextVersion String?    // e.g. "v2026-06-22" — version of the checkbox text shown
  ipAddress          String?
  userAgent          String?

  // Human context
  actorId         String?       // userId of the staff member who made the change (null = guest self-service)
  notes           String?       // free-text reason, e.g. "customer called to unsubscribe"

  createdAt       DateTime      @default(now())

  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest       Guest       @relation(fields: [guestId],      references: [id], onDelete: Cascade)
  clubMember  ClubMember? @relation(fields: [clubMemberId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([guestId])
  @@index([clubMemberId])
  @@index([restaurantId, createdAt])
  @@map("consent_audits")
}

enum ConsentType {
  SMS_MARKETING   // general SMS marketing consent
  BIRTHDAY_SMS    // birthday-specific SMS
  ANNIVERSARY_SMS // anniversary-specific SMS
  SURVEY          // survey / feedback request
  CLUB_MEMBERSHIP // joining / leaving the club
  EMAIL_MARKETING
}

enum ConsentAction {
  GRANTED
  REVOKED
  UPDATED // value changed but still positive (e.g. smsConsent true→true, marketingConsent true→false)
}

enum ConsentSource {
  BOOKING_FLOW     // guest checked opt-in during online reservation
  CLUB_JOIN_FORM   // guest submitted the /join/:token form
  FEEDBACK_FORM    // consent captured via feedback flow
  HOST_MANUAL      // staff member changed consent in the admin portal
  IMPORT           // bulk import / backfill script
  API              // direct API call (e.g. POS integration)
  UNSUBSCRIBE_LINK // guest clicked the unsubscribe link in an SMS
}

// ─── Unsubscribe Tokens ───────────────────────────────────────────────────────
// Tokenised one-click unsubscribe infrastructure.
// Raw token is NEVER stored — only its SHA-256 hex digest.
// URL sent in SMS: https://www.ironbooking.com/unsubscribe/{rawToken}

model UnsubscribeToken {
  id           String    @id @default(uuid())
  tokenHash    String    @unique // SHA-256(rawToken) — raw token never persisted
  restaurantId String
  guestId      String
  clubMemberId String?
  phone        String    // phone snapshot at generation time (for audit)
  expiresAt    DateTime  // 90 days from creation
  usedAt       DateTime? // null = not yet clicked; set on first valid use
  createdAt    DateTime  @default(now())

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest      Guest       @relation(fields: [guestId],      references: [id], onDelete: Cascade)
  clubMember ClubMember? @relation(fields: [clubMemberId], references: [id], onDelete: SetNull)

  @@index([restaurantId, guestId])
  @@index([expiresAt])
  @@map("unsubscribe_tokens")
}
