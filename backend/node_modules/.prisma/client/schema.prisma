generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServicePeriod {
  BREAKFAST
  BRUNCH
  LUNCH
  DINNER
  LATE_NIGHT
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  HOST
  PHONE
  ONLINE
  WALK_IN
}

model Restaurant {
  id              String @id @default(cuid())
  name            String
  defaultDuration Int    @default(90)

  reservations   Reservation[]
  tables         RestaurantTable[]
  servicePeriods ServicePeriodConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RestaurantTable {
  id           String  @id @default(cuid())
  restaurantId String
  name         String
  capacity     Int
  isActive     Boolean @default(true)
  posX         Int     @default(0)
  posY         Int     @default(0)

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model Reservation {
  id           String  @id @default(cuid())
  restaurantId String
  tableId      String?
  customerId   String?

  guestName  String
  guestPhone String?
  guestEmail String?
  guestCount Int

  startTime     DateTime
  endTime       DateTime
  actualEndTime DateTime?
  durationMin   Int

  servicePeriod ServicePeriod
  status        ReservationStatus @default(PENDING)
  source        ReservationSource @default(HOST)

  isVIP            Boolean @default(false)
  guestNotes       String?
  staffNotes       String?
  confirmationCode String? @unique

  capacityOverride     Boolean @default(false)
  reservedSoonOverride Boolean @default(false)
  overrideNote         String?
  overrideApprovedBy   String?

  restaurant Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([tableId])
  @@index([status])
  @@index([source])
  @@index([startTime])
  @@index([endTime])
  @@index([restaurantId, startTime])
  @@index([restaurantId, status, startTime])
  @@index([restaurantId, tableId, startTime, endTime])
}

model ServicePeriodConfig {
  id           String        @id @default(cuid())
  restaurantId String
  period       ServicePeriod
  startHour    Int
  endHour      Int
  isActive     Boolean       @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, period])
  @@index([restaurantId])
}
